{
  "manifest_version": 3,
  "name": "Canopy",
  "version": "1.1.0",
  "permissions": [
    "bookmarks",
    "storage",
    "favicon",
    "contextMenus",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://wallhaven.cc/*",
    "https://w.wallhaven.cc/*",
      "https://th.wallhaven.cc/*",
      "https://pub-1fcf1661114842b0b4459512cb05dd05.r2.dev/*"
    ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://wallhaven.cc https://w.wallhaven.cc https://th.wallhaven.cc https://pub-1fcf1661114842b0b4459512cb05dd05.r2.dev; media-src *"
  },
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    },
    "default_title": "Canopy"
  }
}
