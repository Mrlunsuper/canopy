{
  "manifest_version": 3,
  "name": "Canopy",
  "version": "1.0.0",
  "permissions": [
    "bookmarks",
    "storage",
    "favicon"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    },
    "default_title": "Canopy"
  }
}
